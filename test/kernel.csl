param memcpy_params: comptime_struct;
param chunkSize: i32;
param peId: i16;

const memcpy = @import_module("<memcpy/memcpy>", memcpy_params);
const math = @import_module("<math>");

const dstream = @import_module("<downstream/dstream/main>");

var cases = @zeros([chunkSize * 2]u32);
var ptr_cases : [*]u32 = &cases;

var results = @zeros([chunkSize]u32);
var ptr_results : [*]u32 = &results;

fn launch_assign_storage_site(algo: u32) void {
  for(@range(u32, chunkSize)) |case| {
    const S = cases[2*case];
    const T = cases[2*case + 1];
    if (algo == 0) {
      const has_capacity = dstream.circular_algo.has_ingest_capacity(S, T);
      results[case] = (
        if (has_capacity) dstream.circular_algo.assign_storage_site(S, T)
        else S + 1
      );
    } else if (algo == 1) {
      const has_capacity = dstream.steady_algo.has_ingest_capacity(S, T);
      results[case] = (
        if (has_capacity) dstream.steady_algo.assign_storage_site(S, T)
        else S + 1
      );
    } else if (algo == 2) {
      const has_capacity = dstream.stretched_algo.has_ingest_capacity(S, T);
      results[case] = (
        if (has_capacity) dstream.stretched_algo.assign_storage_site(S, T)
        else S + 1
      );
    } else if (algo == 3) {
      const has_capacity = dstream.tilted_algo.has_ingest_capacity(S, T);
      results[case] = (
        if (has_capacity) dstream.tilted_algo.assign_storage_site(S, T)
        else S + 1
      );
    } else if (algo == 4) {
      const has_capacity = dstream.hybrid_0_circular_2_steady_3_algo.has_ingest_capacity(S, T);
      results[case] = (
        if (has_capacity) dstream.hybrid_0_circular_2_steady_3_algo.assign_storage_site(S, T)
        else S + 1
      );
    } else if (algo == 5) {
      const has_capacity = dstream.hybrid_0_circular_2_tilted_3_algo.has_ingest_capacity(S, T);
      results[case] = (
        if (has_capacity) dstream.hybrid_0_circular_2_tilted_3_algo.assign_storage_site(S, T)
        else S + 1
      );
    } else if (algo == 6) {
      const has_capacity = dstream.hybrid_0_steady_1_circular_2_algo.has_ingest_capacity(S, T);
      results[case] = (
        if (has_capacity) dstream.hybrid_0_steady_1_circular_2_algo.assign_storage_site(S, T)
        else S + 1
      );
    } else if (algo == 7) {
      const has_capacity = dstream.hybrid_0_steady_1_stretched_2_algo.has_ingest_capacity(S, T);
      results[case] = (
        if (has_capacity) dstream.hybrid_0_steady_1_stretched_2_algo.assign_storage_site(S, T)
        else S + 1
      );
    } else if (algo == 8) {
      const has_capacity = dstream.hybrid_0_steady_1_tilted_2_algo.has_ingest_capacity(S, T);
      results[case] = (
        if (has_capacity) dstream.hybrid_0_steady_1_tilted_2_algo.assign_storage_site(S, T)
        else S + 1
      );
    } else if (algo == 9) {
      const has_capacity = dstream.hybrid_0_steady_1_tilted_2_circular_3_algo.has_ingest_capacity(S, T);
      results[case] = (
        if (has_capacity) dstream.hybrid_0_steady_1_tilted_2_circular_3_algo.assign_storage_site(S, T)
        else S + 1
      );
    } else if (algo == 10) {
      const has_capacity = dstream.hybrid_0_steady_2_circular_3_algo.has_ingest_capacity(S, T);
      results[case] = (
        if (has_capacity) dstream.hybrid_0_steady_2_circular_3_algo.assign_storage_site(S, T)
        else S + 1
      );
    } else if (algo == 11) {
      const has_capacity = dstream.hybrid_0_steady_2_tilted_3_algo.has_ingest_capacity(S, T);
      results[case] = (
        if (has_capacity) dstream.hybrid_0_steady_2_tilted_3_algo.assign_storage_site(S, T)
        else S + 1
      );
    } else if (algo == 12) {
      const has_capacity = dstream.hybrid_0_tilted_1_circular_2_algo.has_ingest_capacity(S, T);
      results[case] = (
        if (has_capacity) dstream.hybrid_0_tilted_1_circular_2_algo.assign_storage_site(S, T)
        else S + 1
      );
    } else if (algo == 13) {
      const has_capacity = dstream.hybrid_0_tilted_2_circular_3_algo.has_ingest_capacity(S, T);
      results[case] = (
        if (has_capacity) dstream.hybrid_0_tilted_2_circular_3_algo.assign_storage_site(S, T)
        else S + 1
      );
    } else if (algo == 14) {
      const has_capacity = dstream.hybrid_0_tilted_2_steady_3_algo.has_ingest_capacity(S, T);
      results[case] = (
        if (has_capacity) dstream.hybrid_0_tilted_2_steady_3_algo.assign_storage_site(S, T)
        else S + 1
      );
    } else {
      @assert(false);
    }
  }
  memcpy.unblock_cmd_stream();
}

const in_q_lauch : input_queue = @get_input_queue(2);
const launch_task_id : data_task_id = @get_data_task_id(in_q_lauch);

comptime {
  @export_symbol(ptr_cases, "cases");
  @export_symbol(ptr_results, "results");
  @export_symbol(launch_assign_storage_site);
  @rpc(launch_task_id);
  @initialize_queue(in_q_lauch, .{ .color = memcpy.LAUNCH });
}
