param memcpy: imported_module;
param chunkSize: i32;

const dstream = @import_module("<downstream/dstream/main>");

var cases = @zeros([chunkSize * 2]u32);
var ptr_cases : [*]u32 = &cases;

var results = @zeros([chunkSize]u32);
var ptr_results : [*]u32 = &results;

fn launch_assign_storage_site(algo: u32) void {
  for(@range(u32, chunkSize)) |case| {
    const S = cases[2*case];
    const T = cases[2*case + 1];

    if (algo == 0) {
      const has_capacity = dstream.hybrid_0_circular_2_steady_3_algo.has_ingest_capacity(S, T);
      results[case] = (
        if (has_capacity) dstream.hybrid_0_circular_2_steady_3_algo.assign_storage_site(S, T)
        else S + 1
      );
    } else if (algo == 1) {
      const has_capacity = dstream.hybrid_0_circular_2_tilted_3_algo.has_ingest_capacity(S, T);
      results[case] = (
        if (has_capacity) dstream.hybrid_0_circular_2_tilted_3_algo.assign_storage_site(S, T)
        else S + 1
      );
    } else if (algo == 2) {
      const has_capacity = dstream.hybrid_0_steady_1_tilted_2_circular_3_algo.has_ingest_capacity(S, T);
      results[case] = (
        if (has_capacity) dstream.hybrid_0_steady_1_tilted_2_circular_3_algo.assign_storage_site(S, T)
        else S + 1
      );
    } else if (algo == 3) {
      const has_capacity = dstream.hybrid_0_steady_2_circular_3_algo.has_ingest_capacity(S, T);
      results[case] = (
        if (has_capacity) dstream.hybrid_0_steady_2_circular_3_algo.assign_storage_site(S, T)
        else S + 1
      );
    } else if (algo == 4) {
      const has_capacity = dstream.hybrid_0_steady_2_tilted_3_algo.has_ingest_capacity(S, T);
      results[case] = (
        if (has_capacity) dstream.hybrid_0_steady_2_tilted_3_algo.assign_storage_site(S, T)
        else S + 1
      );
    } else if (algo == 5) {
      const has_capacity = dstream.hybrid_0_tilted_2_circular_3_algo.has_ingest_capacity(S, T);
      results[case] = (
        if (has_capacity) dstream.hybrid_0_tilted_2_circular_3_algo.assign_storage_site(S, T)
        else S + 1
      );
    } else if (algo == 6) {
      const has_capacity = dstream.hybrid_0_tilted_2_steady_3_algo.has_ingest_capacity(S, T);
      results[case] = (
        if (has_capacity) dstream.hybrid_0_tilted_2_steady_3_algo.assign_storage_site(S, T)
        else S + 1
      );
    } else {
      @assert(false);
    }
  }
  memcpy.unblock_cmd_stream();
}
